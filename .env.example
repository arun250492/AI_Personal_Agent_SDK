# AI Personal Agent SDK Configuration
# Copy this file to .env and fill in your values

# Required: OpenAI API Key
# Get yours from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Zapier API Key for automations
# Get yours from: https://zapier.com/developer
ZAPIER_API_KEY=your_zapier_api_key_here

# Optional: Google Credentials for Gmail/Calendar integration
# Follow setup instructions in README.md
GOOGLE_CREDENTIALS_PATH=path/to/your/google/credentials.json

# Optional: Custom encryption key (auto-generated if not provided)
ENCRYPTION_KEY=your_custom_encryption_key_here

# Optional: Data storage path
DATA_STORAGE_PATH=./agent_data

# Optional: Web UI port
UI_PORT=8080

# Optional: Monitoring interval in seconds
MONITORING_INTERVAL=60